# Æsethien — Environment Variables
# Copy this file to .env and fill in your keys
# .env is in .gitignore — your keys are never uploaded to GitHub

# Noun Project API (free tier — 5000 requests/month)
# Get keys at: https://thenounproject.com/developers/
NOUN_PROJECT_KEY=your_key_here
NOUN_PROJECT_SECRET=your_secret_here

# Supabase (for mission state persistence — Phase 2)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_anon_key_here

# WorkAdventure upload (if self-hosting maps)
# UPLOAD_MODE=GH_PAGES
